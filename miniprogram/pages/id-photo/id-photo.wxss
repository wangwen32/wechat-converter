/* pages/id-photo/id-photo.wxss */
.card { margin-bottom: 24rpx; }
.upload-area { display: flex; flex-direction: column; align-items: center; padding: 60rpx; border: 2rpx dashed var(--border-medium); border-radius: var(--radius-lg); cursor: pointer; }
.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: var(--text-primary); font-weight: 500; }
.upload-hint { font-size: 22rpx; color: var(--text-tertiary); margin-top: 8rpx; }
.preview-row { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.thumb { width: 100%; max-height: 300rpx; border-radius: var(--radius-sm); }
.file-clear { font-size: 24rpx; color: var(--color-error); cursor: pointer; }
.color-picker { display: flex; align-items: center; gap: 12rpx; padding: 16rpx; background: var(--bg-hover); border-radius: var(--radius-sm); }
.color-dot { width: 36rpx; height: 36rpx; border-radius: 50%; border: 1rpx solid var(--border-medium); }
.btn-primary { margin: 0 0 24rpx; }
.result-img { width: 100%; border-radius: var(--radius-sm); margin-top: 12rpx; }
.btn-secondary { height: 72rpx; line-height: 72rpx; text-align: center; background: var(--color-primary-bg); color: var(--color-primary); border-radius: var(--radius-sm); font-size: 26rpx; margin-top: 16rpx; }
