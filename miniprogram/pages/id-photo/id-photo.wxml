<view class="page">
  <view class="card">
    <view class="section-title">上传照片</view>
    <view wx:if="{{ !selected }}" class="upload-area" bindtap="onChooseImage">
      <text class="upload-icon">📸</text>
      <text class="upload-text">拍摄或选择照片</text>
      <text class="upload-hint">请选择正面免冠照片</text>
    </view>
    <view wx:else class="preview-row">
      <image class="thumb" src="{{ imagePath }}" mode="aspectFit"></image>
      <text class="file-clear" bindtap="onClearImage">✕ 重新选择</text>
    </view>
  </view>
  <view class="card" wx:if="{{ selected }}">
    <view class="section-title">选择背景色</view>
    <picker mode="selector" range="{{ colorNames }}" value="{{ colorIndex }}" bindchange="onColorChange">
      <view class="color-picker">
        <view class="color-dot" style="background: {{ bgColor }};"></view>
        <text>{{ colors[colorIndex].name }}</text>
        <text>▼</text>
      </view>
    </picker>
  </view>
  <button class="btn-primary" wx:if="{{ selected }}" disabled="{{ processing }}" bindtap="onProcess">
    {{ processing ? '⏳ 制作中...' : '📷 开始制作' }}
  </button>
  <view wx:if="{{ resultPath }}" class="card">
    <view class="section-title">制作完成</view>
    <image class="result-img" src="{{ resultPath }}" mode="aspectFit"></image>
    <button class="btn-secondary" bindtap="onSave">💾 保存到相册</button>
  </view>
</view>
