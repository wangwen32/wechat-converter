<view class="page">
  <view class="card">
    <view class="section-title">贷款信息</view>
    <view class="form-row">
      <text class="form-label">贷款总额（元）</text>
      <input class="form-input" type="digit" value="{{ totalLoan }}" bindinput="onLoanInput" />
    </view>
    <view class="form-row">
      <text class="form-label">年利率（%）</text>
      <input class="form-input" type="digit" value="{{ yearRate }}" bindinput="onRateInput" />
    </view>
    <view class="form-row">
      <text class="form-label">贷款年限（年）</text>
      <input class="form-input" type="digit" value="{{ years }}" bindinput="onYearInput" />
    </view>
    <view class="form-row">
      <text class="form-label">还款方式</text>
      <picker mode="selector" range="{{ ['等额本息', '等额本金'] }}" value="{{ method === 'equal-payment' ? 0 : 1 }}" bindchange="onMethodChange">
        <text>{{ method === 'equal-payment' ? '等额本息' : '等额本金' }}</text>
      </picker>
    </view>
  </view>

  <button class="btn-primary" bindtap="onCalc">开始计算</button>

  <view wx:if="{{ result }}" class="card result-card">
    <view class="section-title">计算结果</view>
    <view class="result-row"><text class="rl">还款方式</text><text class="rv">{{ result.methodName }}</text></view>
    <view class="result-row"><text class="rl">月供</text><text class="rv highlight">{{ result.monthly }} 元</text></view>
    <view class="result-row"><text class="rl">利息总额</text><text class="rv">{{ result.totalInterest }} 元</text></view>
    <view class="result-row"><text class="rl">还款总额</text><text class="rv">{{ result.totalPayment }} 元</text></view>
    <text wx:if="{{ result.note }}" style="font-size: 22rpx; color: var(--text-tertiary); margin-top: 12rpx; display: block;">{{ result.note }}</text>
  </view>
</view>
