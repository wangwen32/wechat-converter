/* ══════════════════════════════════════════
   首页 — 文档转换大师 v2.0
   设计语言：简洁 · 高级 · 专业
   ══════════════════════════════════════════ */

/* ── 页面 ── */
.page {
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: var(--bg-primary);
}

/* ══════════════════════════════════════════
   第一屏：Banner
   ══════════════════════════════════════════ */

.banner {
  position: relative;
  margin: 24rpx var(--space-lg) 0;
  height: 280rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
}

.banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1677FF 0%, #4096FF 50%, #60A5FA 100%);
}

.banner-glow {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}
.banner-glow-1 {
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, #FFFFFF 0%, transparent 70%);
  top: -120rpx; right: -80rpx;
}
.banner-glow-2 {
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, #FFFFFF 0%, transparent 70%);
  bottom: -100rpx; left: -60rpx;
}

.banner-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 36rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.banner-title-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 20rpx;
}
.banner-brand {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}
.banner-brand-accent {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

.banner-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.banner-tag {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  border: 0.5px solid rgba(255, 255, 255, 0.15);
}

.banner-features {
  display: flex;
  gap: 24rpx;
}
.banner-feature {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  position: relative;
}
.banner-feature + .banner-feature::before {
  content: '·';
  position: absolute;
  left: -16rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* ══════════════════════════════════════════
   第二屏：核心功能卡
   ══════════════════════════════════════════ */

.core-section {
  padding: 0 var(--space-lg);
  margin-top: var(--space-lg);
}

.core-card {
  position: relative;
  height: 220rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.core-card-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1677FF 0%, #4096FF 100%);
}

.core-card-hover {
  transform: scale(0.98);
}

.core-card-content {
  position: relative;
  z-index: 1;
  padding: 36rpx 32rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.core-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.core-card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}
.core-card-icon {
  font-size: 40rpx;
}

.core-card-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.core-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
.core-card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.core-card-arrow {
  display: flex;
  align-items: center;
  gap: 10rpx;
  align-self: flex-end;
}
.core-card-arrow-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}
.core-card-arrow-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  transition: transform 0.2s;
}
.core-card-hover .core-card-arrow-icon {
  transform: translateX(6rpx);
}

/* ══════════════════════════════════════════
   第三屏：功能分类列表（横向滚动标签）
   ══════════════════════════════════════════ */

.cat-section {
  padding: 0 var(--space-lg);
  margin-bottom: 16rpx;
}
.cat-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tool-horizontal {
  overflow: hidden;
  white-space: nowrap;
}
.tool-h-inner {
  display: inline-flex;
  gap: 12rpx;
}

.tool-chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
  cursor: pointer;
  transition: all 0.15s;
  border: 1rpx solid var(--border-light);
}
.tool-chip-hover {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}
.tool-chip-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.text-gen-chip {
  display: flex !important;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(22,119,255,0.05), rgba(64,150,255,0.08));
  border-color: rgba(22,119,255,0.15);
  border-radius: var(--radius-lg) !important;
}
.chip-arrow {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-left: 12rpx;
}

/* ══════════════════════════════════════════
   第四屏：最近使用
   ══════════════════════════════════════════ */

.recent-list {
  margin: 0 var(--space-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 24rpx var(--space-lg);
  cursor: pointer;
  transition: background 0.15s;
}
.recent-item:active {
  background: var(--bg-hover);
}
.recent-item + .recent-item {
  border-top: 1rpx solid var(--border-light);
}

.recent-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.recent-icon {
  font-size: 30rpx;
}

.recent-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.recent-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  max-width: 400rpx;
}
.recent-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.recent-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 空状态 */
.recent-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 24rpx;
  gap: 8rpx;
}
.recent-empty-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  opacity: 0.6;
}
.recent-empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.recent-empty-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ══════════════════════════════════════════
   第五屏：休闲娱乐（横向滚动）
   ══════════════════════════════════════════ */

.game-scroll {
  padding: 0 var(--space-lg);
  white-space: nowrap;
  overflow: hidden;
}

.game-scroll-inner {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.game-card {
  position: relative;
  width: 280rpx;
  height: 190rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.2s;
}

.game-card-bg {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
}
.game-bg {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
}
.gomoku-bg {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
}

.game-card-hover {
  transform: scale(0.96);
}

.game-card-icon {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  font-size: 40rpx;
  z-index: 1;
}

.game-card-info {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.game-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}
.game-card-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── 暗色模式已移除 ── */
