/* ══════════════════════════════════════════
   首页 — 米白/深蓝双主题
   ══════════════════════════════════════════ */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 16px;
}

/* ── 头部 ── */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0 28px;
  position: relative;
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  width: 100%;
  position: relative;
  margin-bottom: 20px;
}

/* ── Logo ── */
.logo-wrapper {
  width: 88px;
  height: 88px;
  border-radius: 24px;
  background: linear-gradient(135deg, #2B5CE8, #4A7CF7);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(43, 92, 232, 0.25);
  position: relative;
  overflow: visible;
}

.logo-glow {
  position: absolute;
  top: -8px;
  left: -8px;
  right: -8px;
  bottom: -8px;
  border-radius: 30px;
  background: radial-gradient(circle, rgba(43,92,232,0.12) 0%, transparent 70%);
  z-index: -1;
}

.logo-icon {
  font-size: 40px;
}

/* ── 主题切换 ── */
.theme-toggle {
  position: absolute;
  right: 0;
  top: 0;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  font-size: 22px;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.theme-toggle:active {
  transform: scale(0.85) rotate(180deg);
}

/* ── 标题 ── */
.title {
  font-size: 26px;
  font-weight: 700;
  color: #1A2332;
  margin-bottom: 8px;
  letter-spacing: 1px;
}

.subtitle {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.35);
  letter-spacing: 0.3px;
}

/* ── 入场动画 ── */
.animate-header { animation: fadeInScale 0.6s ease-out both; }
.animate-logo { animation: fadeInScale 0.5s ease-out 0.1s both; }
.animate-title { animation: fadeInUp 0.5s ease-out 0.2s both; }
.animate-subtitle { animation: fadeInUp 0.5s ease-out 0.3s both; }

.animate-card {
  opacity: 0;
  animation: fadeInUp 0.5s ease-out forwards;
}
.card-1 { animation-delay: 0.15s; }
.card-2 { animation-delay: 0.22s; }
.card-3 { animation-delay: 0.29s; }
.card-4 { animation-delay: 0.36s; }
.card-5 { animation-delay: 0.43s; }
.card-6 { animation-delay: 0.50s; }

.animate-more {
  opacity: 0;
  animation: fadeInUp 0.5s ease-out 0.62s forwards;
}

/* ── 功能卡片 ── */
.card-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: 4px;
}

.func-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 18px;
  padding: 18px 20px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.5);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.func-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  border-radius: 0 2px 2px 0;
  opacity: 0;
  transition: opacity 0.3s;
}

.func-card:active {
  transform: scale(0.97);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
}

.func-card:active::before {
  opacity: 1;
}

.func-card:nth-child(1)::before { background: linear-gradient(180deg, #2B5CE8, #4A7CF7); }
.func-card:nth-child(2)::before { background: linear-gradient(180deg, #4A7CF7, #7BA3FF); }
.func-card:nth-child(3)::before { background: linear-gradient(180deg, #6366F1, #818CF8); }
.func-card:nth-child(4)::before { background: linear-gradient(180deg, #0EA5E9, #38BDF8); }
.func-card:nth-child(5)::before { background: linear-gradient(180deg, #8B5CF6, #A78BFA); }
.func-card:nth-child(6)::before { background: linear-gradient(180deg, #EC4899, #F472B6); }

.func-icon {
  width: 54px;
  height: 54px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.func-card:active .func-icon {
  transform: scale(1.1);
}

.pdf-bg { background: linear-gradient(135deg, #E8F0FE, #D0E1FF); }
.word-bg { background: linear-gradient(135deg, #EDF3FF, #DCE8FF); }
.img-bg { background: linear-gradient(135deg, #EEF2FF, #E0E7FF); }
.barcode-bg { background: linear-gradient(135deg, #ECFEFF, #CFFAFE); }
.qrcode-bg { background: linear-gradient(135deg, #F5F3FF, #EDE9FE); }
.watermark-bg { background: linear-gradient(135deg, #FFF1F2, #FFE4E6); }

.icon-text { font-size: 26px; }

.func-info { flex: 1; display: flex; flex-direction: column; gap: 3px; }
.func-title { font-size: 17px; font-weight: 600; color: #1A2332; }
.func-desc { font-size: 13px; color: rgba(0, 0, 0, 0.4); line-height: 1.4; }

.func-tag {
  display: inline-block;
  font-size: 10px;
  color: #fff;
  background: linear-gradient(135deg, #2B5CE8, #4A7CF7);
  border-radius: 8px;
  padding: 1px 8px;
  margin-top: 4px;
  align-self: flex-start;
}

/* ── 箭头 ── */
.arrow-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8px;
  transition: all 0.3s ease;
}

.func-card:active .arrow-circle {
  background: #2B5CE8;
  transform: translateX(3px);
}

.func-card:active .arrow { color: #fff; }

.arrow {
  font-size: 18px;
  color: #2B5CE8;
  font-weight: 600;
  transition: color 0.3s ease;
}

/* ── 特性展示 ── */
.features {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 0 8px;
  gap: 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  flex: 1;
}

.feature-icon { font-size: 22px; }
.feature-text { font-size: 12px; color: rgba(0, 0, 0, 0.3); }

.feature-divider {
  width: 1px;
  height: 30px;
  background: rgba(0, 0, 0, 0.06);
}

/* ── 更多选项 ── */
.more-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 16px 0 8px;
  transition: opacity 0.2s;
}

.more-text { font-size: 14px; color: rgba(0, 0, 0, 0.3); }
.more-arrow { font-size: 18px; color: rgba(0, 0, 0, 0.3); }
.more-entry:active { opacity: 0.5; }

/* ── 底部 ── */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 0 32px;
  gap: 4px;
}

.footer-text { font-size: 11px; color: rgba(0, 0, 0, 0.2); }
