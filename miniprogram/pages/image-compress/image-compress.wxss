/* pages/image-compress/image-compress.wxss */
.card { margin-bottom: 24rpx; }
.upload-area { display: flex; flex-direction: column; align-items: center; padding: 60rpx; border: 2rpx dashed var(--border-medium); border-radius: var(--radius-lg); cursor: pointer; }
.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: var(--text-primary); }
.upload-hint { font-size: 22rpx; color: var(--text-tertiary); margin-top: 8rpx; }
.preview-row { display: flex; align-items: center; gap: 16rpx; }
.thumb { width: 120rpx; height: 120rpx; border-radius: var(--radius-sm); object-fit: cover; }
.file-info { flex: 1; }
.file-name { font-size: 24rpx; color: var(--text-primary); display: block; }
.file-size { font-size: 20rpx; color: var(--text-tertiary); }
.file-clear { font-size: 28rpx; color: var(--color-error); cursor: pointer; }
.slider-row { display: flex; align-items: center; gap: 12rpx; }
.btn-primary { margin: 0 0 16rpx; }
.btn-secondary { height: 72rpx; line-height: 72rpx; text-align: center; background: var(--color-primary-bg); color: var(--color-primary); border-radius: var(--radius-sm); font-size: 26rpx; margin-top: 16rpx; }
