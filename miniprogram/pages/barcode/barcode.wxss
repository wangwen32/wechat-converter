/* ══════════════════════════════════════════
   条形码页 — 双主题
   ══════════════════════════════════════════ */

.container { display: flex; flex-direction: column; padding: 0; min-height: 100vh; }

/* ── 页面标题 ── */
.page-header { display: flex; flex-direction: column; align-items: center; padding: 32px 0 16px; }
.page-icon-bg {
  width: 64px; height: 64px; border-radius: 18px;
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16px; box-shadow: 0 6px 20px rgba(14, 165, 233, 0.3);
}
.page-icon { font-size: 32px; }
.page-title { font-size: 22px; font-weight: 700; color: #1A2332; margin-bottom: 6px; }
.page-desc { font-size: 13px; color: rgba(0, 0, 0, 0.35); }

/* ── 文本输入 ── */
.text-input {
  width: 100%; height: 48px;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 12px; padding: 0 16px;
  font-size: 16px; color: #1A2332; box-sizing: border-box;
}
.text-input:focus { border-color: #2B5CE8; box-shadow: 0 0 0 3px rgba(43, 92, 232, 0.08); }
.input-placeholder { color: rgba(0, 0, 0, 0.25); font-size: 15px; }

/* ── 选择器 ── */
.picker-box {
  width: 100%; height: 48px;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 12px; display: flex; align-items: center;
  justify-content: space-between; padding: 0 16px; box-sizing: border-box;
}
.picker-label { font-size: 15px; color: #1A2332; }
.picker-arrow { font-size: 10px; color: rgba(0, 0, 0, 0.25); }

/* ── 结果展示 ── */
.result-card { margin-top: 0; }
.barcode-display {
  display: flex; justify-content: center; padding: 20px 10px;
  background: rgba(255, 255, 255, 0.5); border-radius: 12px;
  border: 1px solid rgba(0, 0, 0, 0.04);
}
.barcode-img { width: 100%; max-width: 320px; height: auto; }
.result-info { display: flex; flex-direction: column; gap: 4px; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(0, 0, 0, 0.04); }
.result-info-label { font-size: 12px; color: rgba(0, 0, 0, 0.35); }
.action-row { display: flex; justify-content: center; gap: 12px; margin-top: 16px; }

.btn-action.btn-save {
  width: auto; min-width: 160px; height: 40px; line-height: 40px;
  font-size: 14px; font-weight: 500; border-radius: 10px;
  text-align: center; border: none;
  background: rgba(255, 255, 255, 0.7); color: #2B5CE8; padding: 0 24px;
}
.btn-action.btn-save:active { opacity: 0.7; background: rgba(255, 255, 255, 0.9); }

/* ── 提示 ── */
.tips { margin-top: 4px; }
.tip-item { font-size: 13px; color: rgba(0, 0, 0, 0.35); line-height: 1.9; }
.tip-bold { font-weight: 600; color: #1A2332; }

/* ── 二维码页共享 ── */
.qrcode-display {
  display: flex; justify-content: center; padding: 24px;
  background: rgba(255, 255, 255, 0.5); border-radius: 12px;
  border: 1px solid rgba(0, 0, 0, 0.04);
}
.qrcode-img { width: 220px; height: 220px; }
.input-hint { font-size: 12px; color: rgba(0, 0, 0, 0.25); margin-top: 8px; }
.btn-copy {
  width: auto; min-width: 140px; height: 40px; line-height: 40px;
  font-size: 14px; font-weight: 500; border-radius: 10px;
  text-align: center; border: none;
  background: rgba(0, 0, 0, 0.04); color: #1A2332; padding: 0 20px;
}
.btn-copy:active { opacity: 0.7; }

/* ── 更多页共享 ── */
.switch-track {
  width: 48px; height: 28px; border-radius: 14px;
  background: rgba(0, 0, 0, 0.1); position: relative; transition: background 0.2s;
}
.switch-track.switch-on { background: #2B5CE8; }
.switch-thumb {
  width: 24px; height: 24px; border-radius: 50%; background: #fff;
  position: absolute; top: 2px; left: 2px; transition: transform 0.2s;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
}
.switch-track.switch-on .switch-thumb { transform: translateX(20px); }

/* ── 底部 ── */
.footer { display: flex; justify-content: center; padding: 32px 0; }
.footer-text { font-size: 12px; color: rgba(0, 0, 0, 0.2); }
