<!-- pages/game/game.wxml -->
<view class="container"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd">

  <canvas canvas-id="gameCanvas" class="game-canvas"></canvas>

  <!-- 暂停按钮（游戏中显示） -->
  <view wx:if="{{ gameState === 'playing' }}" class="pause-btn" bindtap="onPause">
    <text class="pause-icon">⏸</text>
  </view>

  <!-- 分数 -->
  <view class="score-board">
    <text class="score-label">得分</text>
    <text class="score-value">{{ score }}</text>
  </view>

  <!-- 开始界面 -->
  <view wx:if="{{ gameState === 'ready' }}" class="overlay">
    <view class="overlay-content">
      <text class="overlay-title">✏️ 飞机大战</text>
      <text class="overlay-desc">铅笔线稿风格 · 手指滑动控制</text>
      <button class="btn-start" bindtap="onStartGame">开始游戏</button>
    </view>
  </view>

  <!-- 暂停界面 -->
  <view wx:elif="{{ gameState === 'paused' }}" class="overlay">
    <view class="overlay-content">
      <text class="overlay-icon">⏸</text>
      <text class="overlay-title">暂停</text>
      <text class="overlay-desc">当前得分：{{ score }}</text>
      <button class="btn-start" bindtap="onResume">继续游戏</button>
      <text class="btn-back" bindtap="onQuit">退出游戏</text>
    </view>
  </view>

  <!-- 结束界面 -->
  <view wx:elif="{{ gameState === 'gameover' }}" class="overlay">
    <view class="overlay-content">
      <text class="overlay-icon">💥</text>
      <text class="overlay-title">游戏结束</text>
      <text class="overlay-score">得分：{{ score }}</text>
      <text class="overlay-best">最高分：{{ bestScore }}</text>
      <button class="btn-start" bindtap="onStartGame">再来一局</button>
      <text class="btn-back" bindtap="onGoHome">返回首页</text>
    </view>
  </view>
</view>
