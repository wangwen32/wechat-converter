/* ══════════════════════════════════════════
   飞机大战 — 手绘铅笔线稿风格
   ══════════════════════════════════════════ */

.container {
  position: relative; width: 100vw; height: 100vh;
  background: #FFF8F0; overflow: hidden;
}

/* ── 素描纸网格 ── */
.grid-bg {
  position: absolute; inset: 0; z-index: 0;
  background-image:
    linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px);
  background-size: 28px 28px;
}

/* ── 手绘飞机 ✈️ ── */
.player {
  position: absolute; width: 52px; height: 60px;
  transform: translate(-50%, -50%); z-index: 10;
}
.plane-body { width: 100%; height: 100%; position: relative; }

/* 机身 — 手绘虚线轮廓 */
.plane-body::before {
  content: ''; position: absolute;
  top: 4px; left: 50%; transform: translateX(-50%);
  width: 14px; height: 36px;
  border: 2px dashed rgba(44,44,44,0.8);
  border-radius: 7px 7px 3px 3px;
  background: rgba(44,44,44,0.04);
}
/* 机头三角 */
.plane-body::after {
  content: ''; position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 9px solid transparent;
  border-right: 9px solid transparent;
  border-bottom: 14px solid rgba(44,44,44,0.7);
}
/* 左翼 — 手绘虚线 */
.wing-left {
  position: absolute; top: 18px; left: -2px;
  width: 22px; height: 8px;
  border: 2px dashed rgba(44,44,44,0.6);
  border-right: none;
  border-radius: 4px 0 0 4px;
  background: rgba(44,44,44,0.03);
}
/* 右翼 */
.wing-right {
  position: absolute; top: 18px; right: -2px;
  width: 22px; height: 8px;
  border: 2px dashed rgba(44,44,44,0.6);
  border-left: none;
  border-radius: 0 4px 4px 0;
  background: rgba(44,44,44,0.03);
}
/* 尾翼 */
.tail {
  position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 7px solid transparent;
  border-right: 7px solid transparent;
  border-top: 9px solid rgba(44,44,44,0.6);
}

/* ── 手绘子弹 ── */
.bullet {
  position: absolute; width: 4px; height: 16px; z-index: 5;
}
.bullet-head {
  width: 100%; height: 100%;
  border: 1.5px dashed rgba(44,44,44,0.7);
  border-radius: 2px;
  background: rgba(44,44,44,0.05);
}

/* ── 敌机 — 手绘菱形 ── */
.enemy {
  position: absolute;
  border: 2px dashed rgba(44,44,44,0.7);
  background: rgba(44,44,44,0.04);
  clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  z-index: 5;
}

/* ── 手绘爆炸 - 散开笔触 ── */
.ex-area {
  position: absolute; width: 10px; height: 10px;
  transform: translate(-50%, -50%); z-index: 15;
  pointer-events: none;
}
.ex-ring {
  position: absolute; inset: -12px;
  border-radius: 50%;
  border: 2px dashed rgba(44,44,44,0.5);
  opacity: 0;
  animation: exSketch 0.45s ease-out forwards;
}
.ex-r2 { animation-delay: 0.1s; border-style: dotted; border-width: 2px; }
.ex-r3 { animation-delay: 0.2s; border-style: dashed; border-width: 1.5px; }

@keyframes exSketch {
  0% { transform: scale(0.2); opacity: 0.7; }
  60% { opacity: 0.4; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* ── 分数 ── */
.score-board {
  position: absolute; top: 48px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
  z-index: 20; pointer-events: none;
}
.score-label { font-size: 12px; color: rgba(0,0,0,0.18); letter-spacing: 2px; }
.score-value { font-size: 40px; font-weight: 700; color: rgba(0,0,0,0.1); line-height: 1; margin-top: 2px; }

/* ── 暂停 ── */
.pause-btn {
  position: absolute; top: 56px; right: 16px;
  width: 40px; height: 40px; line-height: 40px; text-align: center;
  font-size: 20px; border-radius: 50%;
  background: rgba(0,0,0,0.04); z-index: 20;
}
.pause-btn:active { background: rgba(0,0,0,0.08); }

/* ── 覆盖层 ── */
.overlay {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,248,240,0.93); z-index: 30;
}
.overlay-box { display: flex; flex-direction: column; align-items: center; gap: 12px; }
.overlay-title { font-size: 26px; font-weight: 700; color: #1A2332; }
.overlay-desc { font-size: 14px; color: rgba(0,0,0,0.3); }
.overlay-score { font-size: 20px; font-weight: 600; color: #1A2332; }
.overlay-best { font-size: 14px; color: rgba(0,0,0,0.3); }
.btn-primary {
  min-width: 160px; height: 44px; line-height: 44px;
  background: #1A2332; color: #FFF8F0; font-size: 16px; font-weight: 600;
  border-radius: 22px; text-align: center; border: none; padding: 0 32px;
}
.btn-primary:active { opacity: 0.8; }
.link-btn { font-size: 14px; color: rgba(0,0,0,0.25); padding: 8px 0; }
.link-btn:active { opacity: 0.5; }
