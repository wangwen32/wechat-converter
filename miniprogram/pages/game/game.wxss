/* ══════════════════════════════════════════
   飞机大战 - 铅笔线稿风格
   ══════════════════════════════════════════ */

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #FFF8F0;
  overflow: hidden;
}

.game-canvas {
  width: 100%;
  height: 100%;
}

/* ── 暂停按钮 ── */
.pause-btn {
  position: absolute;
  top: 64px;
  right: 16px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.pause-btn:active {
  background: rgba(0,0,0,0.12);
}
.pause-icon {
  font-size: 20px;
}

/* ── 分数 ── */
.score-board {
  position: absolute;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 5;
  pointer-events: none;
}

.score-label {
  font-size: 12px;
  color: rgba(0, 0, 0, 0.3);
  letter-spacing: 2px;
}

.score-value {
  font-size: 36px;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.15);
  line-height: 1;
  margin-top: 2px;
}

/* ── 覆盖层 ── */
.overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 248, 240, 0.92);
  z-index: 20;
}

.overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 40px;
}

.overlay-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.overlay-title {
  font-size: 28px;
  font-weight: 700;
  color: #1A2332;
}

.overlay-desc {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.4);
  margin-bottom: 16px;
}

.overlay-score {
  font-size: 20px;
  font-weight: 600;
  color: #1A2332;
}

.overlay-best {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.4);
  margin-bottom: 12px;
}

.btn-start {
  min-width: 180px;
  height: 48px;
  line-height: 48px;
  background: #1A2332;
  color: #FFF8F0;
  font-size: 16px;
  font-weight: 600;
  border-radius: 24px;
  text-align: center;
  border: none;
  padding: 0 32px;
}

.btn-start:active {
  opacity: 0.8;
}

.btn-back {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.3);
  padding: 8px 0;
}

.btn-back:active {
  opacity: 0.6;
}
