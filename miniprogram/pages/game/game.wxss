/* ══════════════════════════════════════════
   DOM 版飞机大战 — 铅笔线稿风格
   ══════════════════════════════════════════ */
.container {
  position: relative; width: 100vw; height: 100vh;
  background: #FFF8F0; overflow: hidden;
}

/* ── 玩家飞机 ── */
.player {
  position: absolute; width: 44px; height: 50px;
  transform: translate(-50%, -50%);
  z-index: 10;
}
.player-body {
  width: 0; height: 0;
  border-left: 14px solid transparent;
  border-right: 14px solid transparent;
  border-bottom: 40px solid #2C2C2C;
  position: relative;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
}

/* ── 子弹 ── */
.bullet {
  position: absolute; width: 3px; height: 12px;
  background: #2C2C2C; border-radius: 1px;
  z-index: 5;
}

/* ── 敌机 ── */
.enemy {
  position: absolute; width: 28px; height: 28px;
  background: #2C2C2C;
  clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  z-index: 5;
}

/* ── 爆炸 ── */
.explosion {
  position: absolute;
  width: 10px; height: 10px;
  transform: translate(-50%, -50%);
  z-index: 15;
  pointer-events: none;
}
.ex-particle {
  position: absolute;
  width: 4px; height: 4px;
  background: #2C2C2C;
  border-radius: 50%;
}

/* ── 分数 ── */
.score-board {
  position: absolute; top: 60px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
  z-index: 20; pointer-events: none;
}
.score-label { font-size: 12px; color: rgba(0,0,0,0.25); letter-spacing: 2px; }
.score-value { font-size: 36px; font-weight: 700; color: rgba(0,0,0,0.12); }

/* ── 暂停按钮 ── */
.pause-btn {
  position: absolute; top: 64px; right: 16px;
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(0,0,0,0.04);
  display: flex; align-items: center; justify-content: center;
  z-index: 20;
}
.pause-btn:active { background: rgba(0,0,0,0.08); }
.pause-btn-text { font-size: 20px; }

/* ── 覆盖层 ── */
.overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,248,240,0.93); z-index: 30;
}
.overlay-box {
  display: flex; flex-direction: column; align-items: center; gap: 12px;
}
.overlay-title { font-size: 26px; font-weight: 700; color: #1A2332; }
.overlay-desc { font-size: 14px; color: rgba(0,0,0,0.35); }
.overlay-score { font-size: 20px; font-weight: 600; color: #1A2332; }
.overlay-best { font-size: 14px; color: rgba(0,0,0,0.35); }

.btn-primary {
  min-width: 160px; height: 44px; line-height: 44px;
  background: #1A2332; color: #FFF8F0; font-size: 16px; font-weight: 600;
  border-radius: 22px; text-align: center; border: none; padding: 0 32px;
}
.btn-primary:active { opacity: 0.8; }

.link-btn {
  font-size: 14px; color: rgba(0,0,0,0.3); padding: 8px 0;
}
.link-btn:active { opacity: 0.5; }
