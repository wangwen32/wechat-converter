/* pages/timestamp/timestamp.wxss */
.card { margin-bottom: 24rpx; }
.row { display: flex; align-items: center; gap: 12rpx; margin: 16rpx 0; }
.input { flex: 1; height: 72rpx; border: 1rpx solid var(--border-medium); border-radius: var(--radius-sm); padding: 0 16rpx; font-size: 28rpx; }
.label { font-size: 26rpx; color: var(--text-secondary); flex-shrink: 0; }
.result-box { background: var(--color-primary-bg); border-radius: var(--radius-sm); padding: 24rpx; text-align: center; margin-top: 12rpx; }
.result-text { font-size: 32rpx; font-weight: 600; color: var(--color-primary); word-break: break-all; }
.copy-hint { font-size: 20rpx; color: var(--text-tertiary); margin-top: 6rpx; display: block; }
.btn-small { height: 60rpx; line-height: 60rpx; text-align: center; background: var(--bg-hover); border-radius: var(--radius-sm); font-size: 24rpx; color: var(--text-primary); margin-top: 12rpx; }
