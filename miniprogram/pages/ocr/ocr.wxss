/* pages/ocr/ocr.wxss */
.card { margin-bottom: 24rpx; }
.upload-area { display: flex; flex-direction: column; align-items: center; padding: 60rpx; border: 2rpx dashed var(--border-medium); border-radius: var(--radius-lg); cursor: pointer; }
.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: var(--text-primary); font-weight: 500; }
.upload-hint { font-size: 22rpx; color: var(--text-tertiary); margin-top: 8rpx; }
.image-preview { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.preview-img { width: 100%; max-height: 400rpx; border-radius: var(--radius-sm); }
.file-clear { font-size: 24rpx; color: var(--color-error); cursor: pointer; }
.btn-primary { margin: 0 0 24rpx; }
.result-card { }
.result-content { font-size: 28rpx; line-height: 1.8; color: var(--text-primary); white-space: pre-wrap; word-break: break-all; }
.copy-btn { display: inline-block; padding: 12rpx 24rpx; background: var(--color-primary-bg); color: var(--color-primary); border-radius: var(--radius-sm); font-size: 24rpx; margin-top: 16rpx; }
.confidence-row { display: flex; justify-content: space-between; padding: 12rpx 0; margin-bottom: 12rpx; border-bottom: 1rpx solid var(--border-light); }
.confidence-label { font-size: 24rpx; color: var(--text-secondary); }
.confidence-value { font-size: 24rpx; color: var(--color-success); font-weight: 600; }
