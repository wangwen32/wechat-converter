<!-- pages/qrcode/qrcode.wxml -->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-icon-bg">
      <text class="page-icon">📱</text>
    </view>
    <text class="page-title">二维码生成</text>
    <text class="page-desc">将文本链接或任意信息生成二维码</text>
  </view>

  <!-- 输入区域 -->
  <view class="card">
    <view class="section-title">输入内容</view>

    <textarea
      class="text-area"
      placeholder="输入文本、网址、联系方式等信息..."
      placeholder-class="input-placeholder"
      value="{{ inputData }}"
      bindinput="onInputChange"
      maxlength="500"
      disabled="{{ generating }}"
      auto-height
    />

    <view class="input-hint">提示：输入网址会自动生成可扫描的二维码</view>
  </view>

  <!-- 生成按钮 -->
  <view class="card">
    <button
      class="btn-primary btn-press"
      bindtap="onGenerate"
      disabled="{{ !canGenerate || generating }}"
    >
      <text wx:if="{{ generating }}">⏳ 生成中...</text>
      <text wx:else>🚀 生成二维码</text>
    </button>
  </view>

  <!-- 结果展示 -->
  <view wx:if="{{ resultUrl }}" class="card result-card">
    <view class="section-title">生成结果</view>
    <view class="qrcode-display">
      <image class="qrcode-img" src="{{ resultUrl }}" mode="widthFix"></image>
    </view>
    <view class="result-info">
      <text class="result-info-label">内容: {{ inputData }}</text>
    </view>
    <view class="action-row">
      <button class="btn-action btn-save" bindtap="onSaveImage" size="mini">
        💾 保存到相册
      </button>
      <button class="btn-action btn-copy" bindtap="onCopyLink" size="mini">
        📋 复制内容
      </button>
    </view>
  </view>

  <!-- 使用提示 -->
  <view class="card tips">
    <view class="section-title">使用说明</view>
    <view class="tip-item">· 输入任意文本、网址均可生成二维码</view>
    <view class="tip-item">· 支持微信扫一扫识别</view>
    <view class="tip-item">· 采用高容错编码，部分遮挡仍可识别</view>
  </view>
</view>
