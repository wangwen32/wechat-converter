<view class="page">
  <view class="card">
    <view class="section-title">单位换算</view>
    <picker mode="selector" range="{{ catNames }}" value="{{ catIndex }}" bindchange="onCatChange">
      <view class="picker-box"><text>{{ catNames[catIndex] }}</text><text>▼</text></view>
    </picker>
  </view>
  <view class="card convert-card">
    <input class="convert-input" type="digit" value="{{ inputVal }}" bindinput="onInput" placeholder="输入数值" />
    <picker mode="selector" range="{{ currentUnits }}" value="{{ fromIdx }}" bindchange="onFromChange">
      <view class="unit-box"><text>{{ fromUnit }}</text><text>▼</text></view>
    </picker>
    <text class="equal-sign">=</text>
    <text class="convert-result">{{ resultVal || '等待输入' }}</text>
    <picker mode="selector" range="{{ currentUnits }}" value="{{ toIdx }}" bindchange="onToChange">
      <view class="unit-box"><text>{{ toUnit }}</text><text>▼</text></view>
    </picker>
  </view>
</view>
