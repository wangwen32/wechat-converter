/* pages/unit-convert/unit-convert.wxss */
.card { margin-bottom: 24rpx; }
.picker-box { display: flex; justify-content: space-between; align-items: center; padding: 16rpx; background: var(--bg-hover); border-radius: var(--radius-sm); }
.convert-card { display: flex; flex-direction: column; gap: 16rpx; }
.convert-input { font-size: 40rpx; font-weight: 700; text-align: center; padding: 20rpx; border: 1rpx solid var(--border-medium); border-radius: var(--radius-sm); }
.unit-box { display: flex; justify-content: space-between; padding: 12rpx 16rpx; background: var(--bg-hover); border-radius: var(--radius-sm); }
.equal-sign { text-align: center; font-size: 36rpx; color: var(--text-tertiary); }
.convert-result { text-align: center; font-size: 44rpx; font-weight: 700; color: var(--color-primary); padding: 12rpx; }
