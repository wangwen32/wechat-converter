/* ── CSS 变量（设计 Token） ── */
page {
  /* 背景 */
  --bg-primary: #F7F9FC;
  --bg-secondary: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-hover: #F3F4F6;

  /* 品牌色 */
  --color-primary: #1677FF;
  --color-primary-light: #4096FF;
  --color-primary-bg: rgba(22, 119, 255, 0.08);
  --color-primary-bg-hover: rgba(22, 119, 255, 0.12);
  --color-success: #22C55E;
  --color-warning: #F59E0B;
  --color-error: #EF4444;

  /* 文字 */
  --text-primary: #1F2937;
  --text-secondary: #6B7280;
  --text-tertiary: #9CA3AF;
  --text-placeholder: #D1D5DB;
  --text-inverse: #FFFFFF;

  /* 边框 / 分割线 */
  --border-light: #F3F4F6;
  --border-medium: #E5E7EB;

  /* 阴影 */
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.06);
  --shadow-xl: 0 12px 40px rgba(0, 0, 0, 0.08);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue',
    'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* ── 页面容器 ── */
.page {
  padding: 0 var(--space-lg);
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: var(--bg-primary);
}

/* ── 卡片 ── */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: var(--space-lg);
}

/* ── 分区标题 ── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) 0 var(--space-md);
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
}
.section-action {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* ── 按钮 ── */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--color-primary);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 4px 16px rgba(22, 119, 255, 0.25);
  transition: opacity 0.15s;
  letter-spacing: 0.5rpx;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-primary[disabled] {
  background: var(--text-placeholder);
  box-shadow: none;
}

/* ── 占位符文字 ── */
.placeholder-text {
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* ── 分割线 ── */
.divider {
  height: 2rpx;
  background: var(--border-light);
  margin: var(--space-md) 0;
}

/* ── 工具类 ── */
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── 状态栏安全区域 ── */
.safe-top {
  height: var(--status-bar-height, 88rpx);
}

/* ── 全局关键帧动画 ── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes ripple {
  0% { width: 72rpx; height: 72rpx; opacity: 0.4; }
  100% { width: 160rpx; height: 160rpx; opacity: 0; }
}
@keyframes confettiFall {
  0% { transform: translateY(-20rpx) rotate(0deg); opacity: 1; }
  100% { transform: translateY(400rpx) rotate(720deg); opacity: 0; }
}
